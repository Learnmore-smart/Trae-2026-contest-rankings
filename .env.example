# =============================================================================
# 环境变量分类说明（Cloud Run 部署指南）
# -----------------------------------------------------------------------------
# PUBLIC  → 非敏感配置，可直接通过 Cloud Run 环境变量设置（YAML / gcloud run deploy --set-env-vars）
# SECRET  → 敏感密钥，必须通过 Cloud Run Secret Manager 注入（gcloud run deploy --set-secrets）
#          或在 Cloud Run 控制台 "Secrets" 选项卡配置
# =============================================================================

# =============================================================================
# [PUBLIC] 项目标识与 AI 提供商基础配置
# =============================================================================
OPENROUTER_SITE_URL=https://rateministere.com
OPENROUTER_APP_NAME=TRAE Contest 2026
GOOGLE_CLOUD_PROJECT=trae-contest-ranking-2026
FIREBASE_PROJECT_ID=trae-contest-ranking-2026

# =============================================================================
# [PUBLIC] NVIDIA AI 服务配置
# =============================================================================
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_PRIMARY_MODEL=moonshotai/kimi-k2.6
NVIDIA_FALLBACK_MODELS=z-ai/glm-5.1,deepseek-ai/deepseek-v4-flash
NVIDIA_IMAGE_MODEL=moonshotai/kimi-k2.6
NVIDIA_IMAGE_FALLBACK_MODEL=minimaxai/minimax-m3

# =============================================================================
# [PUBLIC] OpenRouter AI 服务配置
# =============================================================================
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,google/gemma-4-31b-it:free

# =============================================================================
# [PUBLIC] AI 调用策略配置
# =============================================================================
AI_PROVIDER_ORDER=nvidia,openrouter
AI_ZERO_BUDGET_ONLY=true
AI_RPM_LIMIT=30
AI_MAX_RETRIES_PER_MODEL=2
AI_REQUEST_TIMEOUT_MS=120000
TRAE_JUDGE_CONCURRENCY=1

# =============================================================================
# [PUBLIC] 爬虫与抓取配置
# =============================================================================
TRAE_SCRAPER_USER_AGENT=TRAE Contest Rank Bot; contact: your@email.com
TRAE_MAX_SCRAPE_PAGES_PER_RUN=10
TRAE_MAX_TOPIC_DETAILS_PER_RUN=100
TRAE_MAX_JUDGE_PER_RUN=50
TRAE_MAX_FORUM_LOOKUPS_PER_RUN=0
TRAE_FORUM_LOOKUP_CONCURRENCY=16
TRAE_FORUM_MIN_REQUEST_MS=150
TRAE_FORUM_MAX_RETRIES=5

# =============================================================================
# [SECRET] API 密钥 — 必须使用 Cloud Run Secret Manager
#         本地开发时填写真实值，部署到 Cloud Run 时通过 Secret Manager 注入
# =============================================================================
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
TRAE_ADMIN_TOKEN=your_admin_token_here
TRAE_CRON_SECRET=your_cron_secret_here
FIREBASE_SERVICE_ACCOUNT_KEY=your_base64_encoded_firebase_service_account_json_here
